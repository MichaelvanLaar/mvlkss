includes:
    - phpstan-baseline.neon

parameters:
    level: 6
    paths:
        - site/controllers
        - site/snippets
        - site/plugins
        - site/config
        - tests

    excludePaths:
        - site/plugins/*/vendor/*
        - vendor/*
        - kirby/*

    bootstrapFiles:
        - vendor/autoload.php

    ignoreErrors:
        # Kirby uses magic methods and dynamic properties
        - '#Access to an undefined property Kirby\\Cms\\.*::\$.*#'
        - '#Call to an undefined method Kirby\\Cms\\.*::.*#'
        # Allow mixed types for Kirby field values
        - '#Method .* has parameter .* with no value type specified in iterable type array#'
        # Relax iterable/generic type enforcement for Kirby's dynamic API
        - identifier: missingType.iterableValue
        - identifier: missingType.generics

    # Do not fail when ignoreErrors patterns match nothing (Kirby errors vary by version)
    reportUnmatchedIgnoredErrors: false
